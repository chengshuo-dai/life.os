# Life.OS Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─── Core ────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
NEXT_PUBLIC_APP_NAME=Life.OS
NEXT_PUBLIC_API_VERSION=v1

# ─── Vercel KV (Production) ──────────────────────────
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── Stripe Payment Integration ───────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_ENABLED=false

# Pre-configured Price IDs from Stripe Dashboard
# STRIPE_PRICE_TIER_1=price_...
# STRIPE_PRICE_TIER_2=price_...
# STRIPE_PRICE_TIER_3=price_...
# STRIPE_PRICE_TIER_4=price_...

# ─── WeChat Pay Integration ───────────────────────────
# Get these from https://pay.weixin.qq.com
WECHAT_PAY_MERCHANT_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NUMBER=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_CERT=
